rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns a document (has userId field matching auth.uid)
    function isOwner(userId) {
      return isAuthenticated() && userId == request.auth.uid;
    }
    
    // Helper function to check if user is creating/updating with their own userId
    function isCreatingOwnData() {
      return isAuthenticated() && 
             request.resource.data.userId == request.auth.uid;
    }

    // Properties collection
    // Users can only read/write their own properties
    match /properties/{propertyId} {
      // Allow read if user is authenticated (queries filter by userId in the app)
      allow read: if isAuthenticated();
      
      // Allow create if user is authenticated and sets their own userId
      allow create: if isCreatingOwnData();
      
      // Allow update if user owns the property
      allow update: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid &&
                       request.resource.data.userId == request.auth.uid;
      
      // Allow delete if user owns the property
      allow delete: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid;
    }

    // Placements collection
    // Users can read/write placements for properties they own
    match /placements/{placementId} {
      // Allow read/write for authenticated users
      // The app verifies property ownership when needed
      allow read, write: if isAuthenticated();
    }

    // User profiles/settings collection
    // Users can only manage their own profile data
    match /users/{userId} {
      // Users can read their own profile
      allow read: if isOwner(userId);
      
      // Users can create their own profile
      allow create: if isCreatingOwnData();
      
      // Users can update their own profile
      allow update: if isOwner(userId) && 
                       request.resource.data.userId == request.auth.uid;
      
      // Users can delete their own profile
      allow delete: if isOwner(userId);
    }

    // User settings collection
    // Users can only manage their own settings
    match /user_settings/{userId} {
      // Users can read their own settings
      allow read: if isOwner(userId);
      
      // Users can create their own settings
      allow create: if isCreatingOwnData();
      
      // Users can update their own settings
      allow update: if isOwner(userId) && 
                       request.resource.data.userId == request.auth.uid;
      
      // Users can delete their own settings
      allow delete: if isOwner(userId);
    }

    // Products collection (if stored in Firestore)
    // Users can manage products associated with their properties
    match /products/{productId} {
      // Allow read/write for authenticated users
      // Products are linked to properties, and property ownership is verified in the app
      allow read, write: if isAuthenticated();
    }

    // Devices collection (if stored in Firestore)
    // Users can manage their own devices
    match /devices/{deviceId} {
      // Allow read if user owns the device or device doesn't exist yet
      allow read: if isAuthenticated();
      
      // Allow create if user sets their own userId
      allow create: if isCreatingOwnData();
      
      // Allow update if user owns the device
      allow update: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid &&
                       request.resource.data.userId == request.auth.uid;
      
      // Allow delete if user owns the device
      allow delete: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid;
    }

    // User preferences/notifications collection
    match /user_preferences/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Account data collection
    match /accounts/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Settings collection (general app settings per user)
    match /settings/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Animals collection (birds, chickens, etc.)
    // Users can manage animals linked to their properties and products
    match /animals/{animalId} {
      // Allow read if user owns the animal
      allow read: if isAuthenticated() && 
                     (resource.data.userId == request.auth.uid || 
                      !exists(/databases/$(database)/documents/animals/$(animalId)));
      
      // Allow create if user is authenticated and sets their own userId
      allow create: if isCreatingOwnData();
      
      // Allow update if user owns the animal
      allow update: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid &&
                       request.resource.data.userId == request.auth.uid;
      
      // Allow delete if user owns the animal
      allow delete: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid;
    }

    // Fallback: Deny access to any other collections by default
    // Add specific rules above for any new collections you create
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
