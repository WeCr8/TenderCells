{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/fallow.schema.json",
  "entry": [
    "src/main.tsx",
    "src/App.tsx",
    "vite.config.ts",
    "cypress.config.ts"
  ],
  "ignorePatterns": [
    "applications/**",
    "cypress/**",
    "dist/**",
    "node_modules/**",
    "playwright-report/**",
    "test-results/**",
    ".fallow/**",
    "*.tsbuildinfo",
    "vite.config.js",
    "vite.config.d.ts"
  ],
  "duplicates": {
    "ignore": [
      "applications/**",
      "dist/**",
      "playwright-report/**",
      "test-results/**",
      "docs/**",
      "scripts/**",
      "cypress/**"
    ]
  },
  "ignoreDependencies": [
    "cypress"
  ],
  "ignoreUnresolvedImports": [
    "@/**"
  ]
}
