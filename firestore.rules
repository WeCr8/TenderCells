rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns a document (has userId field matching auth.uid)
    function isOwner(userId) {
      return isAuthenticated() && userId == request.auth.uid;
    }
    
    // Helper function to check if user is creating/updating with their own userId
    function isCreatingOwnData() {
      return isAuthenticated() && 
             request.resource.data.userId == request.auth.uid;
    }

    function isOwnedResource() {
      return isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    function keepsOwner() {
      return isAuthenticated() &&
             resource.data.userId == request.auth.uid &&
             request.resource.data.userId == request.auth.uid;
    }

    function deviceDoc(deviceId) {
      return get(/databases/$(database)/documents/devices/$(deviceId));
    }

    function ownsDevice(deviceId) {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/devices/$(deviceId)) &&
             deviceDoc(deviceId).data.userId == request.auth.uid;
    }

    function deviceItemCreateMatches(deviceId) {
      return ownsDevice(deviceId) &&
             request.resource.data.deviceId == deviceId;
    }

    function deviceItemKeepsDevice(deviceId) {
      return ownsDevice(deviceId) &&
             resource.data.deviceId == deviceId &&
             request.resource.data.deviceId == deviceId;
    }

    // Properties collection
    // Users can only read/write their own properties
    match /properties/{propertyId} {
      // Allow read only for the property owner.
      allow read: if isOwnedResource();
      
      // Allow create if user is authenticated and sets their own userId
      allow create: if isCreatingOwnData();
      
      // Allow update if user owns the property
      allow update: if keepsOwner();
      
      // Allow delete if user owns the property
      allow delete: if isOwnedResource();
    }

    // Placements collection
    // Users can read/write placements for properties they own
    match /placements/{placementId} {
      allow read: if isAuthenticated() &&
                     exists(/databases/$(database)/documents/properties/$(resource.data.propertyId)) &&
                     get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
                       exists(/databases/$(database)/documents/properties/$(request.resource.data.propertyId)) &&
                       get(/databases/$(database)/documents/properties/$(request.resource.data.propertyId)).data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
                       exists(/databases/$(database)/documents/properties/$(resource.data.propertyId)) &&
                       get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.userId == request.auth.uid &&
                       request.resource.data.propertyId == resource.data.propertyId;
      allow delete: if isAuthenticated() &&
                       exists(/databases/$(database)/documents/properties/$(resource.data.propertyId)) &&
                       get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.userId == request.auth.uid;
    }

    // User profiles/settings collection
    // Users can only manage their own profile data
    match /users/{userId} {
      // Users can read their own profile
      allow read: if isOwner(userId);
      
      // Users can create their own profile
      allow create: if isCreatingOwnData();
      
      // Users can update their own profile
      allow update: if isOwner(userId) && 
                       request.resource.data.userId == request.auth.uid;
      
      // Users can delete their own profile
      allow delete: if isOwner(userId);
    }

    // User settings collection
    // Users can only manage their own settings
    match /user_settings/{userId} {
      // Users can read their own settings
      allow read: if isOwner(userId);
      
      // Users can create their own settings
      allow create: if isCreatingOwnData();
      
      // Users can update their own settings
      allow update: if isOwner(userId) && 
                       request.resource.data.userId == request.auth.uid;
      
      // Users can delete their own settings
      allow delete: if isOwner(userId);
    }

    // Products collection (if stored in Firestore)
    // Users can manage products associated with their properties
    match /products/{productId} {
      allow read: if isOwnedResource();
      allow create: if isCreatingOwnData();
      allow update: if keepsOwner();
      allow delete: if isOwnedResource();
    }

    // Devices collection (if stored in Firestore)
    // Users can manage their own devices
    match /devices/{deviceId} {
      allow read: if isOwnedResource();
      
      // Allow create if user sets their own userId
      allow create: if isCreatingOwnData();
      
      // Allow update if user owns the device
      allow update: if keepsOwner();
      
      // Allow delete if user owns the device
      allow delete: if isOwnedResource();
    }

    // User preferences/notifications collection
    match /user_preferences/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Account data collection
    match /accounts/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Settings collection (general app settings per user)
    match /settings/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Animals collection (birds, chickens, etc.)
    // Users can manage animals linked to their properties and products
    match /animals/{animalId} {
      // Allow read if user owns the animal
      allow read: if isOwnedResource();
      
      // Allow create if user is authenticated and sets their own userId
      allow create: if isCreatingOwnData();
      
      // Allow update if user owns the animal
      allow update: if keepsOwner();
      
      // Allow delete if user owns the animal
      allow delete: if isOwnedResource();
    }

    // Per-device rosters used by the current app:
    // birds/{deviceId}/items/{birdId}
    match /birds/{deviceId}/items/{birdId} {
      allow read, delete: if ownsDevice(deviceId);
      allow create: if ownsDevice(deviceId) &&
                       (!('device' in request.resource.data) || request.resource.data.device == deviceId);
      allow update: if ownsDevice(deviceId) &&
                       (!('device' in resource.data) || resource.data.device == deviceId) &&
                       (!('device' in request.resource.data) || request.resource.data.device == deviceId);
    }

    // Per-device automation schedules used by the current app:
    // schedules/{deviceId}/items/{scheduleId}
    match /schedules/{deviceId}/items/{scheduleId} {
      allow read, delete: if ownsDevice(deviceId);
      allow create: if deviceItemCreateMatches(deviceId);
      allow update: if deviceItemKeepsDevice(deviceId);
    }

    // Fallback: Deny access to any other collections by default
    // Add specific rules above for any new collections you create
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
